# ============================================================
# VARIABLES DE ENTORNO — Ahorro Inteligente en Fármacos
# Copia este archivo a .env.local y completa los valores reales
# NUNCA commitear .env.local al repositorio
# ============================================================

# ── Supabase (REQUERIDO) ─────────────────────────────────────
# Obtener desde: https://app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica

# ── App ──────────────────────────────────────────────────────
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=production

# ── Analytics (opcional) ─────────────────────────────────────
# Poner 'true' para habilitar tracking de eventos de UI
VITE_ANALYTICS_ENABLED=false

# ── NUNCA incluir aquí: ──────────────────────────────────────
# SUPABASE_SERVICE_ROLE_KEY  ← solo en backend/edge functions
# DATABASE_URL               ← solo en backend
# Cualquier clave privada    ← nunca en el cliente
